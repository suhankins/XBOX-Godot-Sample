; Pong's GameInput action map. Loaded by `GameInputBootstrap` at startup
; because `game_input/mapper/default_action_map` is set to this file in
; project.godot.
;
; Bindings:
;   * gameplay paddle:  move_up / move_down — left stick Y + d-pad up/down
;   * UI navigation:    ui_left / ui_right / ui_up / ui_down — d-pad + left
;                       stick (matters for the modifier-pick overlay between
;                       waves; also used by the title screen menu)
;   * UI confirm:       ui_accept — A button
;   * UI cancel/back:   ui_cancel — B button
;   * Roguelike potions: use_consumable_1/2/3 — X / Y / RB
;
; The GameInput addon takes ownership of the controller while running, so
; Godot's default joypad-to-`ui_*` mappings don't fire — the bindings here
; are what makes the controller drive UI navigation and consumable use.

[gd_resource type="GameInputActionMap" load_steps=18 format=3]

[sub_resource type="GameInputBinding" id="GameInputBinding_up_axis"]
action = &"move_up"
source = 101
is_axis = true
axis_threshold = 0.5
axis_invert = true
deadzone = 0.2

[sub_resource type="GameInputBinding" id="GameInputBinding_down_axis"]
action = &"move_down"
source = 101
is_axis = true
axis_threshold = 0.5
axis_invert = false
deadzone = 0.2

[sub_resource type="GameInputBinding" id="GameInputBinding_up_dpad"]
action = &"move_up"
source = 6
is_axis = false

[sub_resource type="GameInputBinding" id="GameInputBinding_down_dpad"]
action = &"move_down"
source = 7
is_axis = false

[sub_resource type="GameInputBinding" id="GameInputBinding_ui_up_dpad"]
action = &"ui_up"
source = 6
is_axis = false

[sub_resource type="GameInputBinding" id="GameInputBinding_ui_down_dpad"]
action = &"ui_down"
source = 7
is_axis = false

[sub_resource type="GameInputBinding" id="GameInputBinding_ui_left_dpad"]
action = &"ui_left"
source = 8
is_axis = false

[sub_resource type="GameInputBinding" id="GameInputBinding_ui_right_dpad"]
action = &"ui_right"
source = 9
is_axis = false

[sub_resource type="GameInputBinding" id="GameInputBinding_ui_left_stick"]
action = &"ui_left"
source = 100
is_axis = true
axis_threshold = 0.5
axis_invert = true
deadzone = 0.4

[sub_resource type="GameInputBinding" id="GameInputBinding_ui_right_stick"]
action = &"ui_right"
source = 100
is_axis = true
axis_threshold = 0.5
axis_invert = false
deadzone = 0.4

[sub_resource type="GameInputBinding" id="GameInputBinding_ui_up_stick"]
action = &"ui_up"
source = 101
is_axis = true
axis_threshold = 0.5
axis_invert = true
deadzone = 0.4

[sub_resource type="GameInputBinding" id="GameInputBinding_ui_down_stick"]
action = &"ui_down"
source = 101
is_axis = true
axis_threshold = 0.5
axis_invert = false
deadzone = 0.4

[sub_resource type="GameInputBinding" id="GameInputBinding_ui_accept_a"]
action = &"ui_accept"
source = 2
is_axis = false

[sub_resource type="GameInputBinding" id="GameInputBinding_ui_cancel_b"]
action = &"ui_cancel"
source = 3
is_axis = false

[sub_resource type="GameInputBinding" id="GameInputBinding_consumable_1_x"]
action = &"use_consumable_1"
source = 4
is_axis = false

[sub_resource type="GameInputBinding" id="GameInputBinding_consumable_2_y"]
action = &"use_consumable_2"
source = 5
is_axis = false

[sub_resource type="GameInputBinding" id="GameInputBinding_consumable_3_rb"]
action = &"use_consumable_3"
source = 11
is_axis = false

[resource]
bindings = Array[Resource]([SubResource("GameInputBinding_up_axis"), SubResource("GameInputBinding_down_axis"), SubResource("GameInputBinding_up_dpad"), SubResource("GameInputBinding_down_dpad"), SubResource("GameInputBinding_ui_up_dpad"), SubResource("GameInputBinding_ui_down_dpad"), SubResource("GameInputBinding_ui_left_dpad"), SubResource("GameInputBinding_ui_right_dpad"), SubResource("GameInputBinding_ui_left_stick"), SubResource("GameInputBinding_ui_right_stick"), SubResource("GameInputBinding_ui_up_stick"), SubResource("GameInputBinding_ui_down_stick"), SubResource("GameInputBinding_ui_accept_a"), SubResource("GameInputBinding_ui_cancel_b"), SubResource("GameInputBinding_consumable_1_x"), SubResource("GameInputBinding_consumable_2_y"), SubResource("GameInputBinding_consumable_3_rb")])
