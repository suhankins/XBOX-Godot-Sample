[node name="ResolveDialog" type="AcceptDialog" parent="Root/Tabs/GameSaves"]
title = "Resolve Game Saves conflict"
ok_button_text = "Cancel"
dialog_text = "Pick a recovery strategy. Each option re-runs add_user_with_ui_async with a different ADD_USER_OPTION_* flag — the system Game Saves dialog will surface if the cloud actually has a conflict to resolve.

• Keep cloud version — accept whatever PlayFab considers the latest upload.
• Roll back to last known good — use the most recently verified earlier save.
• Roll back to last conflict — restore the preserved \"losing\" side from the most recent conflict resolution."
dialog_autowrap = true
size = Vector2i(560, 0)

