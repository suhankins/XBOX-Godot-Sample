# ── Build output ─────────────────────────────────────────────────
build/
out/
x64/

# ── Visual Studio ────────────────────────────────────────────────
.vs/
*.user
*.suo
*.ncb
*.sdf
*.opensdf

# ── CMake ────────────────────────────────────────────────────────
CMakeCache.txt
CMakeFiles/
cmake_install.cmake

# ── Compiled objects ─────────────────────────────────────────────
*.obj
*.o
*.pdb
*.ilk
*.exp
*.lib

# ── Built DLLs (output of CMake build) ──────────────────────────
addons/*/bin/*
addons/godot_playfab/demo/bin/*
sample*/addons/*/bin/*
sample*/**/addons/*/bin/*
sample*/addons/godot_playfab/godot_playfab.gdextension

# ── Mirrored test-support trees (Wave -1 spike: GUT) ────────────
# Configure-time copies of vendored third-party scripts. Source of
# truth lives under addons/<addon>/tests_support/.
sample/*/addons/gut/
sample/*/addons/godot_gdk_tests/
tests/godot/*/addons/

# ── CMake-synced sample addon mirrors ───────────────────────────
# Each sample's addons/godot_<name>/ directory is populated at build
# time by `cmake --build`. Source of truth lives under addons/<addon>/.
# Tracking these would duplicate files and create needless diff noise.
sample/*/addons/godot_gdk/
sample/*/addons/godot_playfab/
sample/*/addons/godot_gameinput/
sample/*/addons/godot_gdk_packaging/

# ── Godot ────────────────────────────────────────────────────────
.godot/
*.import
*.uid

# ── GDK dev registration & packaging artifacts ──────────────────
**/MicrosoftGame.config
**/_gdk_staging/
*.msixvc
*.ekb
*.phd
*_appxmanifest.xml
Validator_*.xml
layout_*.xml
*.toc.xml
meta_*.json
summary_*.json

# ── Dev-time Godot exe copies (for wdapp register) ─────────────
sample/**/*.exe

# ── Placeholder logos (generated for wdapp/makepkg) ─────────────
sample/**/StoreLogo.png
sample/**/Logo150.png
sample/**/Logo44.png
sample/**/Logo480.png
sample/**/SplashScreen.png
sample/**/storelogos/
sample/**/Package/

# ── Export and packaging output ──────────────────────────────────
**/Build/

# ── Copilot session artifacts ────────────────────────────────────
session_context.md

# ── Godot export presets (user-specific Partner Center values) ──
# ── Godot export presets (checked in for base config, users may modify) ──
# sample/**/export_presets.cfg

# ── Sample config (user-specific, generated by tools/setup_sample.ps1) ──
sample/**/sample_config.cfg
sample/**/sample_pf_config.cfg

# ── GDK packaging settings (user-specific editor state) ─────────
**/.gdk_packaging.cfg

# ── OS ───────────────────────────────────────────────────────────
Thumbs.db
.DS_Store
