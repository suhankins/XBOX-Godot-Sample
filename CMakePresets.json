{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
    "configurePresets": [
        {
            "name": "_base",
            "hidden": true,
            "generator": "Visual Studio 17 2022",
            "architecture": "x64",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_CXX_STANDARD": "17",
                "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDLL",
                "CMAKE_MAP_IMPORTED_CONFIG_DEBUG": "Release;",
                "CMAKE_MAP_IMPORTED_CONFIG_RELWITHDEBINFO": "Release;",
                "CMAKE_MAP_IMPORTED_CONFIG_MINSIZEREL": "Release;",
                "BUILD_GODOT_GDK": "ON",
                "BUILD_GODOT_GAMEINPUT": "ON"
            }
        },
        {
            "name": "default",
            "displayName": "Visual Studio 2022 x64",
            "inherits": "_base",
            "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-windows"
            }
        },
        {
            "name": "gdk-only",
            "displayName": "GDK addon only",
            "inherits": "default",
            "binaryDir": "${sourceDir}/build/gdk-only",
            "cacheVariables": {
                "BUILD_GODOT_GDK": "ON",
                "BUILD_GODOT_GAMEINPUT": "OFF",
                "BUILD_GODOT_PLAYFAB": "OFF",
                "VCPKG_MANIFEST_FEATURES": "godot-gdk",
                "VCPKG_MANIFEST_NO_DEFAULT_FEATURES": "ON"
            }
        },
        {
            "name": "gameinput-only",
            "displayName": "GameInput addon only",
            "inherits": "default",
            "binaryDir": "${sourceDir}/build/gameinput-only",
            "cacheVariables": {
                "BUILD_GODOT_GDK": "OFF",
                "BUILD_GODOT_GAMEINPUT": "ON",
                "BUILD_GODOT_PLAYFAB": "OFF",
                "VCPKG_MANIFEST_FEATURES": "godot-gameinput",
                "VCPKG_MANIFEST_NO_DEFAULT_FEATURES": "ON"
            }
        },
        {
            "name": "playfab-only",
            "displayName": "PlayFab addon only",
            "inherits": "default",
            "binaryDir": "${sourceDir}/build/playfab-only",
            "cacheVariables": {
                "BUILD_GODOT_GDK": "OFF",
                "BUILD_GODOT_GAMEINPUT": "OFF",
                "BUILD_GODOT_PLAYFAB": "ON",
                "VCPKG_MANIFEST_FEATURES": "godot-gdk",
                "VCPKG_MANIFEST_NO_DEFAULT_FEATURES": "ON"
            }
        },
        {
            "name": "addon-package",
            "displayName": "Drop-in addon package",
            "inherits": "default",
            "binaryDir": "${sourceDir}/build/addon-package",
            "cacheVariables": {
                "BUILD_GODOT_GDK": "ON",
                "BUILD_GODOT_GAMEINPUT": "ON",
                "BUILD_GODOT_PLAYFAB": "ON",
                "BUILD_GODOT_GDK_PACKAGING": "ON",
                "GDK_BUILD_TESTS": "OFF"
            }
        },
        {
            "name": "installed-gdk",
            "displayName": "Installed GDK on disk (no vcpkg required; GameInput via NuGet)",
            "inherits": "_base",
            "binaryDir": "${sourceDir}/build/installed-gdk",
            "cacheVariables": {
                "GDK_DEPENDENCY_SOURCE": "installed",
                "GAMEINPUT_SOURCE": "nuget"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "displayName": "Debug",
            "configurePreset": "default",
            "configuration": "Debug"
        },
        {
            "name": "release",
            "displayName": "Release",
            "configurePreset": "default",
            "configuration": "Release"
        },
        {
            "name": "debug-gdk",
            "displayName": "Debug (godot_gdk only)",
            "configurePreset": "gdk-only",
            "configuration": "Debug",
            "targets": [
                "godot_gdk"
            ]
        },
        {
            "name": "release-gdk",
            "displayName": "Release (godot_gdk only)",
            "configurePreset": "gdk-only",
            "configuration": "Release",
            "targets": [
                "godot_gdk"
            ]
        },
        {
            "name": "debug-gameinput",
            "displayName": "Debug (godot_gameinput only)",
            "configurePreset": "gameinput-only",
            "configuration": "Debug",
            "targets": [
                "godot_gameinput"
            ]
        },
        {
            "name": "release-gameinput",
            "displayName": "Release (godot_gameinput only)",
            "configurePreset": "gameinput-only",
            "configuration": "Release",
            "targets": [
                "godot_gameinput"
            ]
        },
        {
            "name": "debug-playfab",
            "displayName": "Debug (godot_playfab only)",
            "configurePreset": "playfab-only",
            "configuration": "Debug",
            "targets": [
                "godot_playfab"
            ]
        },
        {
            "name": "release-playfab",
            "displayName": "Release (godot_playfab only)",
            "configurePreset": "playfab-only",
            "configuration": "Release",
            "targets": [
                "godot_playfab"
            ]
        },
        {
            "name": "debug-addon-package",
            "displayName": "Debug (drop-in addon package)",
            "configurePreset": "addon-package",
            "configuration": "Debug",
            "targets": [
                "godot_gdk",
                "godot_playfab",
                "godot_gameinput"
            ]
        },
        {
            "name": "release-addon-package",
            "displayName": "Release (drop-in addon package)",
            "configurePreset": "addon-package",
            "configuration": "Release",
            "targets": [
                "godot_gdk",
                "godot_playfab",
                "godot_gameinput"
            ]
        },
        {
            "name": "debug-installed-gdk",
            "displayName": "Debug (installed GDK)",
            "configurePreset": "installed-gdk",
            "configuration": "Debug"
        },
        {
            "name": "release-installed-gdk",
            "displayName": "Release (installed GDK)",
            "configurePreset": "installed-gdk",
            "configuration": "Release"
        }
    ]
}
