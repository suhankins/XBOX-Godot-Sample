<?xml version="1.0" encoding="UTF-8" ?>
<class name="GDKTitleStorageBlobMetadata" inherits="RefCounted" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/godotengine/godot/master/doc/class.xsd">
	<brief_description>
		Script-visible Xbox Services Title Storage blob metadata.
	</brief_description>
	<description>
		Holds metadata returned by Title Storage metadata, download, and upload APIs.
	</description>
	<tutorials>
	</tutorials>
	<methods>
		<method name="get_blob_path" qualifiers="const"><return type="String" /><description>Returns the blob path.</description></method>
